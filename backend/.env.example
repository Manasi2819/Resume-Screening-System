# ─── PostgreSQL ──────────────────────────────────
POSTGRES_USER=screener_user
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=resume_screener
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── Qdrant Vector DB ─────────────────────────────
# For local dev: set QDRANT_USE_MEMORY=true (no install needed)
# For persistent local server: set QDRANT_USE_MEMORY=false
QDRANT_USE_MEMORY=true
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=resume_chunks

# ─── Groq API ─────────────────────────────────────
# Get your free key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Embedding & Reranker Models ──────────────────
# Downloaded automatically from HuggingFace on first run (~1.3GB)
EMBED_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-large
EMBED_DIM=1024

# ─── Local File Storage ───────────────────────────
UPLOAD_DIR=uploads

# ─── Tesseract OCR (for image resumes/JDs) ────────
# Linux/Docker: leave blank — tesseract is on PATH automatically
# Windows local dev: set this to your Tesseract installation path
# Example: C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
